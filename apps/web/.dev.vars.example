# 형식: CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_<바인딩이름>
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE="postgresql://postgres.hwndnkallorbypiedowm:<PASSWORD>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

